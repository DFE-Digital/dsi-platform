@{
    Layout = "_DsiLayout";

    ViewData[DsiLayoutConstants.ServiceName] = "DfE Sign-in";

    if (User.Identity?.IsAuthenticated == true)
    {
        ViewData[DsiLayoutConstants.SignOutUrl] = Url.Action(
            nameof(AuthController.SignOut),
            MvcNaming.Controller<AuthController>()
        );
    }

    var platformOptions = platformOptionsAccessor.Value;

    var items = new List<NavigationItemViewModel>
    {
        new()
        {
            Href = platformOptions.ServicesUrl,
            Text = "Services",
        },
        new()
        {
            Href = new Uri(platformOptions.ServicesUrl, "organisations"),
            Text = "Organisations",
        }
    };

    if (User.Identity is not null && User.Identity.IsAuthenticated && User.HasApproverClaim())
    {
        items.Add(new()
        {
            Href = new Uri(platformOptions.ServicesUrl, "approvals/users"),
            Text = "Manage users",
        });
        items.Add(new()
        {
            Href = new Uri(platformOptions.ServicesUrl, "access-requests"),
            Text = "Requests",
        });
    }

    items.Add(new()
    {
        Href = platformOptions.ProfileUrl,
        Text = "Profile",
        IsActive = true,
    });

    items.Add(new()
    {
        Href = platformOptions.HelpUrl,
        Text = "Help",
    });

    ViewData[DsiLayoutConstants.ServiceNavigationItems] = items.ToArray();
}
